      "name": "[format('{0}/{1}', format('{0}-ehns', parameters('baseName')), 'cloud-forwarder-listen')]",
      "properties": {
        "rights": [
          "Listen"
        ]
      },
      "dependsOn": [
        "[resourceId('Microsoft.EventHub/namespaces', format('{0}-ehns', parameters('baseName')))]"
      ]
    },
